                    <name>Predefined cuboid 1</name>
                    <geometry>
                        <cuboid>
                            <lengthX>1.</lengthX>
                            <depthY>1.</depthY>
                            <heightZ>1.</heightZ>
                        </cuboid>
                    </geometry>
                </genericComponent>
				<genericComponent uID="invalidPredCuboid">
                    <name>Predefined cuboid with negative length</name>
                    <geometry>
                        <cuboid>
                            <lengthX>-1.</lengthX>
                            <depthY>1.</depthY>
                            <heightZ>1.</heightZ>
                        </cuboid>
                    </geometry>
                </genericComponent>
				<genericComponent uID="invalidPredCuboid_2">
                    <name>Predefined cuboid with invalid mass definition</name>
                    <geometry>
                        <cuboid>
                            <lengthX>1.</lengthX>
                            <depthY>1.</depthY>
                            <heightZ>1.</heightZ>
                        </cuboid>
                    </geometry>
					<mass/>
                </genericComponent>
				<genericComponent uID="invalidPredCylinder">
                    <name>Predefined cylinder with negative radius</name>
                    <geometry>
                        <cylinder>
							<radius>-1.</radius>
							<height>1.</height>
						</cylinder>
                    </geometry>
                </genericComponent>
				<genericComponent uID="invalidPredCone">
                    <name>Predefined cone with negative radius</name>
                    <geometry>
                        <cone>
							<lowerRadius>-1.</lowerRadius>
							<height>1</height>
						</cone>
                    </geometry>
                </genericComponent>
				<genericComponent uID="PredCylinderCone">
                    <name>Predefined cone which is actually a cylinder</name>
                    <geometry>
                        <cone>
							<lowerRadius>1.</lowerRadius>
							<upperRadius>1.</upperRadius>
							<height>1</height>
						</cone>
                    </geometry>
                </genericComponent>
				<genericComponent uID="invalidPredEllipsoid">
                    <name>Predefined ellipsoid with negative radius</name>
                    <geometry>
                        <ellipsoid>
                            <radiusX>-1.</radiusX>
                        </ellipsoid>
                    </geometry>
                </genericComponent>
				<genericComponent uID="invalidPredExternal1">
                    <name>External CAD file without file format</name>
					<geometry>
						<external>
							<linkToFile>nacelle.stp</linkToFile>
							<transformation/>
						</external>
					</geometry>
                </genericComponent>
				<genericComponent uID="invalidPredExternal2">
                    <name>External CAD file with unknown file format</name>
					<geometry>
					    <external>
							<linkToFile format="Stl">nacelle.stp</linkToFile>
							<transformation/>
						</external>
					</geometry>
                </genericComponent>
				<genericComponent uID="predFace">
                    <name>Predefined Face</name>
                    <geometry>
                        <external>
							<linkToFile format="step">face.stp</linkToFile>
                        </external>
                    </geometry>
					<mass>
						<density>0.1</density>
					</mass>
                </genericComponent>
            </genericComponents>
